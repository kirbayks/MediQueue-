@page "/register"
@inject NavigationManager Nav

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-10">
    <MudCard Style="border-radius:16px; overflow:hidden;">

        <!-- Blue Header -->
        <MudPaper Elevation="0" Style="background:#1a73e8; padding:32px; text-align:center; border-radius:0;">

            <div style="width:56px; height:56px; background:rgba(255,255,255,0.2); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 12px;">
                <MudIcon Icon="@Icons.Material.Filled.PersonAdd"
                         Style="color:white; font-size:28px;" />
            </div>

            <MudText Style="color:white; font-size:22px; font-weight:700;">
                Create Account
            </MudText>
            <MudText Style="color:rgba(255,255,255,0.8); font-size:13px; margin-top:4px;">
                Join MediQueue today
            </MudText>

        </MudPaper>

        <!-- Form -->
        <MudCardContent Style="padding:28px;">

            <MudText Style="font-size:12px; color:#6b7280; font-weight:600; letter-spacing:1px; margin-bottom:6px;">
                FULL NAME
            </MudText>
            <MudTextField @bind-Value="fullName"
                          Placeholder="Enter your full name"
                          Variant="Variant.Outlined"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Person"
                          AdornmentColor="Color.Primary"
                          Class="mb-4" />

            <MudText Style="font-size:12px; color:#6b7280; font-weight:600; letter-spacing:1px; margin-bottom:6px;">
                EMAIL ADDRESS
            </MudText>
            <MudTextField @bind-Value="email"
                          Placeholder="Enter your email"
                          Variant="Variant.Outlined"
                          InputType="InputType.Email"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Email"
                          AdornmentColor="Color.Primary"
                          Class="mb-4" />

            <MudText Style="font-size:12px; color:#6b7280; font-weight:600; letter-spacing:1px; margin-bottom:6px;">
                PASSWORD
            </MudText>
            <MudTextField @bind-Value="password"
                          Placeholder="Enter your password"
                          Variant="Variant.Outlined"
                          InputType="InputType.Password"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Lock"
                          AdornmentColor="Color.Primary"
                          Class="mb-4" />

            <MudText Style="font-size:12px; color:#6b7280; font-weight:600; letter-spacing:1px; margin-bottom:6px;">
                CONFIRM PASSWORD
            </MudText>
            <MudTextField @bind-Value="confirmPassword"
                          Placeholder="Confirm your password"
                          Variant="Variant.Outlined"
                          InputType="InputType.Password"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Lock"
                          AdornmentColor="Color.Primary"
                          Class="mb-5" />

            @if (message != "")
            {
                <MudAlert Severity="@alertType" Class="mb-4">
                    @message
                </MudAlert>
            }

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Size="Size.Large"
                       OnClick="HandleRegister"
                       StartIcon="@Icons.Material.Filled.HowToReg"
                       Style="border-radius:8px; font-weight:700; padding:12px;">
                Register
            </MudButton>

            <MudDivider Class="my-4" />

            <MudText Style="text-align:center; font-size:13px; color:#6b7280;">
                Already have an account?
                <MudLink Href="/login" Style="color:#1a73e8; font-weight:600;">
                    Login here
                </MudLink>
            </MudText>

        </MudCardContent>

    </MudCard>
</MudContainer>

@code {
    private string fullName = "";
    private string email = "";
    private string password = "";
    private string confirmPassword = "";
    private string message = "";
    private Severity alertType = Severity.Error;

    private async Task HandleRegister()
    {
        if (fullName == "" || email == "" || password == "")
        {
            alertType = Severity.Error;
            message = "Please fill in all fields!";
            return;
        }

        if (password != confirmPassword)
        {
            alertType = Severity.Error;
            message = "Passwords do not match!";
            return;
        }

        alertType = Severity.Success;
        message = "Registered successfully! Redirecting to login...";
        await Task.Delay(1500);
        Nav.NavigateTo("/login");
    }
}