@page "/about"

<!-- Hero Header -->
<MudPaper Elevation="0" Style="background:#1a73e8; padding:48px 40px; text-align:center; border-radius:0;">

    <MudText Style="display:inline-block; background:rgba(255,255,255,0.15); color:white; font-size:11px; font-weight:600; letter-spacing:2px; padding:5px 18px; border-radius:50px; margin-bottom:16px;">
        WHO WE ARE
    </MudText>

    <MudText Typo="Typo.h4" Style="color:white; font-weight:700; margin-bottom:8px;">
        About MediQueue
    </MudText>

    <MudText Typo="Typo.body1" Style="color:rgba(255,255,255,0.8); max-width:500px; margin:0 auto;">
        We are committed to making healthcare accessible, efficient, and patient-centered
    </MudText>

</MudPaper>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8 mb-8">

    <!-- Mission + Stats -->
    <MudGrid Class="mb-8" AlignItems="Center">

        <!-- Left Mission Text -->
        <MudItem xs="12" sm="6">
            <MudText Typo="Typo.h5" Style="font-weight:700; margin-bottom:16px;">
                Our Mission
            </MudText>
            <MudText Typo="Typo.body1" Style="color:#6b7280; line-height:1.8; margin-bottom:16px;">
                MediQueue was built to bridge the gap between patients and
                healthcare providers. We believe that booking a medical
                appointment should be as easy as a few clicks.
            </MudText>
            <MudText Typo="Typo.body1" Style="color:#6b7280; line-height:1.8;">
                Our platform connects patients with verified and experienced
                doctors, ensuring quality healthcare for everyone anytime,
                anywhere.
            </MudText>
        </MudItem>

        <!-- Right Stats Grid -->
        <MudItem xs="12" sm="6">
            <MudPaper Elevation="0" Style="background:white; border-radius:16px; border:0.5px solid #e5e7eb; padding:24px;">
                <MudGrid>

                    <MudItem xs="6">
                        <MudPaper Elevation="0" Style="background:#f8f9ff; border-radius:12px; padding:16px; text-align:center;">
                            <MudText Style="font-size:28px; font-weight:700; color:#1a73e8;">500+</MudText>
                            <MudText Style="font-size:12px; color:#6b7280;">Happy Patients</MudText>
                        </MudPaper>
                    </MudItem>

                    <MudItem xs="6">
                        <MudPaper Elevation="0" Style="background:#f8f9ff; border-radius:12px; padding:16px; text-align:center;">
                            <MudText Style="font-size:28px; font-weight:700; color:#1a73e8;">50+</MudText>
                            <MudText Style="font-size:12px; color:#6b7280;">Expert Doctors</MudText>
                        </MudPaper>
                    </MudItem>

                    <MudItem xs="6">
                        <MudPaper Elevation="0" Style="background:#f8f9ff; border-radius:12px; padding:16px; text-align:center;">
                            <MudText Style="font-size:28px; font-weight:700; color:#1a73e8;">10+</MudText>
                            <MudText Style="font-size:12px; color:#6b7280;">Years Experience</MudText>
                        </MudPaper>
                    </MudItem>

                    <MudItem xs="6">
                        <MudPaper Elevation="0" Style="background:#f8f9ff; border-radius:12px; padding:16px; text-align:center;">
                            <MudText Style="font-size:28px; font-weight:700; color:#1a73e8;">24/7</MudText>
                            <MudText Style="font-size:12px; color:#6b7280;">Support</MudText>
                        </MudPaper>
                    </MudItem>

                </MudGrid>
            </MudPaper>
        </MudItem>

    </MudGrid>

    <!-- Core Values -->
    <MudText Typo="Typo.h5" Style="font-weight:700; text-align:center; margin-bottom:8px;">
        Our Core Values
    </MudText>
    <MudText Typo="Typo.body2" Style="color:#6b7280; text-align:center; margin-bottom:32px;">
        What drives us every day
    </MudText>

    <MudGrid Class="mb-8">

        <MudItem xs="12" sm="4">
            <MudPaper Elevation="0" Style="background:white; border-radius:12px; padding:28px; border:0.5px solid #e5e7eb; text-align:center;">
                <div style="width:52px; height:52px; background:#e8f0fe; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 16px;">
                    <MudIcon Icon="@Icons.Material.Filled.Verified"
                             Style="color:#1a73e8; font-size:26px;" />
                </div>
                <MudText Typo="Typo.h6" Style="font-weight:700; margin-bottom:8px;">Excellence</MudText>
                <MudText Typo="Typo.body2" Style="color:#6b7280; line-height:1.7;">
                    We strive for the highest standard in medical care and service delivery.
                </MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="4">
            <MudPaper Elevation="0" Style="background:white; border-radius:12px; padding:28px; border:0.5px solid #e5e7eb; text-align:center;">
                <div style="width:52px; height:52px; background:#e8f0fe; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 16px;">
                    <MudIcon Icon="@Icons.Material.Filled.Security"
                             Style="color:#1a73e8; font-size:26px;" />
                </div>
                <MudText Typo="Typo.h6" Style="font-weight:700; margin-bottom:8px;">Trust</MudText>
                <MudText Typo="Typo.body2" Style="color:#6b7280; line-height:1.7;">
                    Your health and privacy are always our top priority and commitment.
                </MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" sm="4">
            <MudPaper Elevation="0" Style="background:white; border-radius:12px; padding:28px; border:0.5px solid #e5e7eb; text-align:center;">
                <div style="width:52px; height:52px; background:#e8f0fe; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 16px;">
                    <MudIcon Icon="@Icons.Material.Filled.People"
                             Style="color:#1a73e8; font-size:26px;" />
                </div>
                <MudText Typo="Typo.h6" Style="font-weight:700; margin-bottom:8px;">Community</MudText>
                <MudText Typo="Typo.body2" Style="color:#6b7280; line-height:1.7;">
                    Building a healthier community one appointment at a time.
                </MudText>
            </MudPaper>
        </MudItem>

    </MudGrid>

    <!-- CTA Section -->
    <MudPaper Elevation="0" Style="background:#1a73e8; border-radius:16px; padding:48px; text-align:center;">
        <MudText Typo="Typo.h5" Style="color:white; font-weight:700; margin-bottom:8px;">
            Ready to Get Started?
        </MudText>
        <MudText Typo="Typo.body1" Style="color:rgba(255,255,255,0.8); margin-bottom:24px;">
            Join thousands of patients who trust MediQueue for their healthcare needs
        </MudText>
        <MudButton Variant="Variant.Filled"
                   Size="Size.Large"
                   Href="/register"
                   StartIcon="@Icons.Material.Filled.CalendarMonth"
                   Style="background:white; color:#1a73e8; border-radius:50px; font-weight:700; padding:12px 32px; margin-right:12px;">
            Book Appointment
        </MudButton>
        <MudButton Variant="Variant.Outlined"
                   Size="Size.Large"
                   Href="/doctors"
                   Style="border-color:rgba(255,255,255,0.7); color:white; border-radius:50px; font-weight:600; padding:12px 32px;">
            Meet Our Doctors
        </MudButton>
    </MudPaper>

</MudContainer>